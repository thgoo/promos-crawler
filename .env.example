# ════════════════════════════════════════════════════════════════════════════
# telegram-crawler — listens to promo channels on Telegram and ships raw
# deals to core-api. Pure forwarder: no link processing, no AI extraction.
# Required keys are marked [REQUIRED].
# ════════════════════════════════════════════════════════════════════════════

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development                  # development | production | test
LOG_LEVEL=debug                       # debug | info | warn | error

# ─── Telegram credentials [REQUIRED] ────────────────────────────────────────
# Obtain at https://my.telegram.org/apps
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here

# Telegram client backend. `mtcute` is the default; legacy `gramjs` is also supported.
TELEGRAM_BACKEND=mtcute               # mtcute | gramjs

# Session — login cookies for the Telegram client.
# Generate the first session with `bun run setup` (this stores it in SESSION_DIR).
SESSION_DIR=./sessions
SESSION_NAME=deal_session

# ─── Crawl target [REQUIRED] ────────────────────────────────────────────────
# Comma-separated list of Telegram channel usernames to monitor.
TARGET_CHATS=@channel1,@channel2

# ─── Media storage ──────────────────────────────────────────────────────────
# Where downloaded photos are written. The path is referenced by core-api
# via the `local_path` field on each deal, so both processes must agree on it.
MEDIA_DIR=./media

# ─── Backend (core-api) [REQUIRED] ──────────────────────────────────────────
# Where each deal is POSTed. Link expansion, affiliate rewriting, and AI
# extraction all happen on the backend now — the crawler just forwards.
# Endpoints used: POST /api/deals, POST /api/deals/image
BACKEND_BASE_URL=http://localhost:8000
BACKEND_SECRET=devsecret
